@page "/analytics"

<PageTitle>Analytics</PageTitle>

<section class="panel">
    <h1>Analytics</h1>
    <p>Use this area for trend charts, conversion cohorts, and custom KPI breakdowns.</p>

    <div style="display:grid; gap:0.8rem; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
        <article class="activity-item">
            <strong>Traffic Quality</strong>
            <p>89.2% sessions from qualified segments</p>
        </article>
        <article class="activity-item">
            <strong>Lead Velocity</strong>
            <p>+12.7% month-over-month growth</p>
        </article>
        <article class="activity-item">
            <strong>Alert Noise</strong>
            <p>-18% false positives after rules tuning</p>
        </article>
    </div>
</section>
